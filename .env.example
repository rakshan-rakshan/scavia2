# Brigade Gateway Voice Lead Qualifier — environment variables
# Copy this file to .env and fill in the values, then `docker compose up`.
#
# MINIMUM TO TEST THE VOICE AGENT: just ANTHROPIC_API_KEY + SARVAM_API_KEY.
#   - No Cartesia key?  English TTS falls back to Sarvam (still talks).
#   - No Supabase?      DEMO mode — leads are logged, not saved to a DB.
# Set the rest for full production lead capture + premium English voice.
#
# Lines marked REQUIRED cause a startup error if blank.
# Lines marked OPTIONAL fall back to the shown default / degrade gracefully.

# ---------------------------------------------------------------------------
# LLM — Anthropic Claude
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=                        # REQUIRED — Anthropic console key (sk-ant-…)
ANTHROPIC_MODEL=claude-sonnet-4-6         # OPTIONAL — Sonnet for low-latency live calls

# ---------------------------------------------------------------------------
# STT — Sarvam saaras:v3
# ---------------------------------------------------------------------------
SARVAM_API_KEY=                           # REQUIRED — shared with Sarvam TTS below
SARVAM_STT_MODEL=saaras:v3               # OPTIONAL — transcribe model; supports mode/prompt

# ---------------------------------------------------------------------------
# TTS (English) — Cartesia
# ---------------------------------------------------------------------------
CARTESIA_API_KEY=                         # OPTIONAL — Cartesia key; omit to use Sarvam for English
CARTESIA_VOICE_ID=                        # OPTIONAL — premium English voice UUID (needs the key too)
CARTESIA_MODEL=sonic-2                    # OPTIONAL — Cartesia model ID

# ---------------------------------------------------------------------------
# TTS (Hindi / Telugu) — Sarvam bulbul:v2  (reuses SARVAM_API_KEY above)
# ---------------------------------------------------------------------------
SARVAM_TTS_MODEL=bulbul:v2               # OPTIONAL — Sarvam Indic TTS model
SARVAM_TTS_SPEAKER=anushka               # OPTIONAL — speaker voice name

# ---------------------------------------------------------------------------
# Database — Supabase (service-role key; server-side only, never expose to client)
# ---------------------------------------------------------------------------
SUPABASE_URL=                             # OPTIONAL — https://<project>.supabase.co (omit for demo mode)
SUPABASE_SERVICE_KEY=                     # OPTIONAL — service_role secret key (omit for demo mode)

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0                              # OPTIONAL — bind address; 0.0.0.0 for Docker/Coolify
PORT=7860                                 # OPTIONAL — HTTP port exposed by uvicorn

# ---------------------------------------------------------------------------
# Phase 2 — Telephony via Acefone (BUILT — browser channel works without these)
# Point your Acefone DID's Voice-Streaming / media-stream webhook at:
#     wss://<your-host>/telephony/ws
# Acefone speaks the Twilio Media Streams protocol (μ-law 8 kHz). These vars are
# OPTIONAL for the app to boot; supply them to provision/operate the DID.
# ---------------------------------------------------------------------------
ACEFONE_API_TOKEN=                        # OPTIONAL — Acefone REST API bearer token
ACEFONE_DID=                              # OPTIONAL — DID / phone number for inbound calls
